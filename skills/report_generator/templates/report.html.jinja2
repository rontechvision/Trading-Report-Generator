<!DOCTYPE html>
<html lang="en"><head><meta charset="utf-8"/>
<title>{{ symbol }} — {{ strategy }}</title>
<script src="https://cdn.plot.ly/plotly-2.35.2.min.js"></script>
<style>
 :root{
  --bg:{{ colors.background }};--surface:{{ colors.surface }};--border:{{ colors.border }};--grid:{{ colors.grid }};
  --text-primary:{{ colors.text_primary }};--text-secondary:{{ colors.text_secondary }};--text-tertiary:{{ colors.text_tertiary }};
  --success:{{ colors.success }};--error:{{ colors.error }};--long:{{ colors.long }};--short:{{ colors.short }};
  --highlight:{{ colors.highlight }};--accent:{{ colors.accent }};--up:{{ colors.up }};--down:{{ colors.down }};
  --row-active:#243044;
 }
 :root[data-theme="light"]{
  --bg:{{ colors_light.background }};--surface:{{ colors_light.surface }};--border:{{ colors_light.border }};--grid:{{ colors_light.grid }};
  --text-primary:{{ colors_light.text_primary }};--text-secondary:{{ colors_light.text_secondary }};--text-tertiary:{{ colors_light.text_tertiary }};
  --success:{{ colors_light.success }};--error:{{ colors_light.error }};--long:{{ colors_light.long }};--short:{{ colors_light.short }};
  --highlight:{{ colors_light.highlight }};--accent:{{ colors_light.accent }};--up:{{ colors_light.up }};--down:{{ colors_light.down }};
  --row-active:#dce8fb;
 }
 body{font-family:{{ typography.font_family }};margin:0;background:var(--bg);color:var(--text-primary)}
 .wrap{max-width:{{ layout.max_width }};margin:0 auto;padding:{{ spacing.xl }}}
 .topbar{display:flex;align-items:flex-start;justify-content:space-between;gap:8px}
 h1{font-size:{{ typography.heading_1.size }};margin:0 0 2px}
 .sub{color:var(--text-secondary);font-size:{{ typography.body.size }};margin:2px 0}
 .theme-toggle{background:var(--surface);border:1px solid var(--border);color:var(--text-primary);border-radius:{{ layout.border_radius }};width:32px;height:32px;font-size:15px;cursor:pointer;line-height:1;flex:none}
 .theme-toggle:hover{opacity:.85}
 .cards{display:flex;flex-wrap:wrap;gap:{{ spacing.md }};margin:{{ spacing.lg }} 0}
 .card{background:var(--surface);border:1px solid var(--border);border-radius:{{ layout.border_radius }};padding:{{ layout.card_padding }};min-width:104px}
 .card .k{color:var(--text-secondary);font-size:{{ typography.small.size }};text-transform:uppercase;letter-spacing:.04em}
 .card .v{font-size:17px;font-weight:600;margin-top:2px}
 #ohlcbar{font-size:{{ typography.body.size }};line-height:1.5;padding:8px 6px 4px;min-height:36px}
 #ohlcbar .tf{color:var(--text-tertiary);margin:0 8px 0 5px}
 #ohlcbar .lbl{color:var(--text-tertiary);margin:0 3px 0 11px}
 #ohlcbar .st{color:var(--text-tertiary);margin-right:6px}
 #chart{height:560px;background:var(--bg);border:1px solid var(--border);border-radius:{{ layout.border_radius }}}
 .hint{color:var(--text-secondary);font-size:{{ typography.small.size }};margin:8px 2px}
 .tablewrap{max-height:430px;overflow:auto;margin-top:6px;border:1px solid var(--border);border-radius:{{ layout.border_radius }}}
 table{border-collapse:collapse;width:100%;font-size:{{ typography.body.size }}}
 th,td{padding:6px 10px;text-align:right;white-space:nowrap}
 th{position:sticky;top:0;background:var(--surface);color:var(--text-secondary);font-weight:600;border-bottom:1px solid var(--border)}
 td.t,th.t,td.d,th.d{text-align:left}
 tbody tr{cursor:pointer;border-bottom:1px solid var(--border)}
 tbody tr:hover{background:var(--surface)}
 tbody tr.active{background:var(--row-active)}
 .pos{color:var(--success)}.neg{color:var(--error)}.long{color:var(--long)}.short{color:var(--short)}
 h2{font-size:{{ typography.heading_2.size }};margin:18px 2px 6px;color:var(--text-primary)}
 .tablepick{display:flex;align-items:center;gap:8px;margin:14px 2px 0;font-size:{{ typography.body.size }};color:var(--text-secondary)}
 .tablepick select{background:var(--surface);color:var(--text-primary);border:1px solid var(--border);border-radius:6px;padding:5px 8px;font-size:{{ typography.body.size }}}
 .tblsection{display:block}
 .tblsection.hidden{display:none}
</style></head><body><div class="wrap">
 <div class="topbar">
  <div>
   <h1>{{ strategy }}</h1>
   <div class="sub">{{ symbol }} · {{ timeframe }} · {{ period }}</div>
   <div class="sub">{{ parameters }}</div>
  </div>
  <button id="themeToggle" class="theme-toggle" onclick="toggleTheme()" title="Toggle light/dark mode">🌙</button>
 </div>
 <div class="cards"><div class="card"><div class="k">Total return</div><div class="v">{{ "+" if metrics.total_return_pct >= 0 else "" }}{{ "%.1f" | format(metrics.total_return_pct) }}%</div></div><div class="card"><div class="k">Sharpe</div><div class="v">{{ "%.2f" | format(metrics.sharpe) }}</div></div><div class="card"><div class="k">Max DD</div><div class="v">{{ "%.1f" | format(metrics.max_drawdown_pct) }}%</div></div><div class="card"><div class="k">Win rate</div><div class="v">{{ "%.1f" | format(metrics.win_rate_pct) }}%</div></div><div class="card"><div class="k">Profit factor</div><div class="v">{{ "%.2f" | format(metrics.profit_factor) }}</div></div><div class="card"><div class="k">Trades</div><div class="v">{{ metrics.total_trades }}</div></div></div>
 <div id="ohlcbar"></div>
 <div id="chart"></div>
 <div class="hint">Click any trade row to mark its entry/exit on the chart and zoom in. Double-click the chart to reset.</div>
 <div class="tablepick">
  <label for="tableSel">Show table:</label>
  <select id="tableSel" onchange="switchTable(this.value)">
   <option value="trades">List of Trades</option>
   <option value="losses">Top 10 losses (this period)</option>
  </select>
 </div>
 <div id="tbl-trades" class="tblsection">
  <h2>List of Trades</h2>
  <div class="tablewrap"><table><thead><tr>
   <th>#</th><th class="d">Dir</th><th class="t">Entry (UTC)</th><th class="t">Exit (UTC)</th>
   <th>Entry</th><th>Exit</th><th>Lev</th><th>Bars</th><th>Return %</th><th>R</th><th>P&L $</th><th>Cum $</th>
  </tr></thead><tbody>
  {%- for trade in trades %}
  <tr data-i="{{ loop.index0 }}">
   <td>{{ trade.id }}</td>
   <td class="d {% if trade.direction == 'long' %}long{% else %}short{% endif %}">{{ trade.direction }}</td>
   <td class="t">{{ trade.entry_time }}</td>
   <td class="t">{{ trade.exit_time }}</td>
   <td>{{ "{:,.2f}".format(trade.entry_price) }}</td>
   <td>{{ "{:,.2f}".format(trade.exit_price) }}</td>
   <td>{{ "%.2f" | format(trade.leverage) }}x</td>
   <td>{{ trade.bars }}</td>
   <td class="{% if trade.return_pct >= 0 %}pos{% else %}neg{% endif %}">{{ "+" if trade.return_pct >= 0 else "" }}{{ "%.2f" | format(trade.return_pct) }}</td>
   <td class="{% if trade.r_multiple >= 0 %}pos{% else %}neg{% endif %}">{{ "+" if trade.r_multiple >= 0 else "" }}{{ "%.2f" | format(trade.r_multiple) }}</td>
   <td class="{% if trade.pnl_usd >= 0 %}pos{% else %}neg{% endif %}">{{ "+" if trade.pnl_usd >= 0 else "" }}{{ "%.2f" | format(trade.pnl_usd) }}</td>
   <td>{{ "+" if trade.cum_pnl >= 0 else "" }}{{ "%.2f" | format(trade.cum_pnl) }}</td>
  </tr>
  {%- endfor %}
  </tbody></table></div>
 </div>
 <div id="tbl-losses" class="tblsection hidden">
  <h2>Top 10 losses (this period)</h2>
  <div class="tablewrap"><table><thead><tr>
   <th>#</th><th class="d">Dir</th><th class="t">Entry (UTC)</th><th class="t">Exit (UTC)</th>
   <th>Entry</th><th>Exit</th><th>Lev</th><th>Bars</th><th>Return %</th><th>R</th><th>P&L $</th><th>Cum $</th>
  </tr></thead><tbody>
  {%- for trade in losing_trades_sorted %}
  <tr data-i="{{ trade.id - 1 }}">
   <td>{{ trade.id }}</td>
   <td class="d {% if trade.direction == 'long' %}long{% else %}short{% endif %}">{{ trade.direction }}</td>
   <td class="t">{{ trade.entry_time }}</td>
   <td class="t">{{ trade.exit_time }}</td>
   <td>{{ "{:,.2f}".format(trade.entry_price) }}</td>
   <td>{{ "{:,.2f}".format(trade.exit_price) }}</td>
   <td>{{ "%.2f" | format(trade.leverage) }}x</td>
   <td>{{ trade.bars }}</td>
   <td class="neg">{{ "%.2f" | format(trade.return_pct) }}</td>
   <td class="neg">{{ "%.2f" | format(trade.r_multiple) }}</td>
   <td class="neg">{{ "%.2f" | format(trade.pnl_usd) }}</td>
   <td>{{ "%.2f" | format(trade.cum_pnl) }}</td>
  </tr>
  {%- endfor %}
  </tbody></table></div>
 </div>
</div><script>
var SYM='{{ symbol }}';
var COLORS_DARK={{ colors | tojson }};
var COLORS_LIGHT={{ colors_light | tojson }};
var COLORS=COLORS_DARK;
var INITIAL_CAPITAL={{ (account.initial_capital or 0) if account else 0 }};
// OHLC price series + indicators, when the caller supplies data.prices / data.indicators
// (see sample_data.json). Falls back to an equity-curve-only chart when prices is empty.
var RAWP={{ (prices or {}) | tojson }};
var PRICE={t:RAWP.timestamps||[],o:RAWP.opens||[],h:RAWP.highs||[],l:RAWP.lows||[],c:RAWP.closes||[]};
var RAWI={{ (indicators or {}) | tojson }};
var ST_UP=RAWI.supertrend_up||[], ST_DN=RAWI.supertrend_down||[], HARSI_LINE=RAWI.harsi||[];
var TRADES=[
  {%- for trade in trades %}
  {id:{{ trade.id }},dir:'{{ trade.direction }}',entry_time:'{{ trade.entry_time }}',exit_time:'{{ trade.exit_time }}',entry_px:{{ trade.entry_price }},exit_px:{{ trade.exit_price }},pnl:{{ trade.pnl_usd }},cum_pnl:{{ trade.cum_pnl }}},
  {%- endfor %}
];
(function(){ // entry/exit equity per trade, used as y-values when there's no price series
 var eq=INITIAL_CAPITAL;
 TRADES.forEach(function(t){ t.entry_eq=eq; t.exit_eq=INITIAL_CAPITAL+t.cum_pnl; eq=t.exit_eq; });
})();

function switchTable(val){
 document.getElementById('tbl-trades').classList.toggle('hidden',val!=='trades');
 document.getElementById('tbl-losses').classList.toggle('hidden',val!=='losses');
}

var hasPrice=PRICE.t.length>0;
var hasHarsi=hasPrice && HARSI_LINE.length>0;
var HI; // trace index of the "Selected" highlight trace, set in renderChart()
var gd=document.getElementById('chart');
var INITIAL_BARS=150; // how many of the most-recent bars/trades to show on first render

function applyTheme(theme){
 document.documentElement.setAttribute('data-theme',theme);
 COLORS=theme==='light'?COLORS_LIGHT:COLORS_DARK;
 var btn=document.getElementById('themeToggle');
 if(btn)btn.textContent=theme==='light'?'🌙':'☀️';
 try{localStorage.setItem('trg-theme',theme);}catch(e){}
 renderChart();
}
function toggleTheme(){
 var cur=document.documentElement.getAttribute('data-theme')||'dark';
 applyTheme(cur==='light'?'dark':'light');
}

function renderChart(){
 var leX=[],leY=[],seX=[],seY=[],exX=[],exY=[],exC=[];
 TRADES.forEach(function(d){
  var ey=hasPrice?d.entry_px:d.entry_eq, xy=hasPrice?d.exit_px:d.exit_eq;
  if(d.dir==='long'){leX.push(d.entry_time);leY.push(ey);}else{seX.push(d.entry_time);seY.push(ey);}
  exX.push(d.exit_time);exY.push(xy);exC.push(d.pnl>=0?COLORS.success:COLORS.error);
 });

 var traces=[];
 if(hasPrice){
  traces.push({x:PRICE.t,open:PRICE.o,high:PRICE.h,low:PRICE.l,close:PRICE.c,type:'candlestick',name:SYM,yaxis:'y',
   increasing:{line:{color:COLORS.up},fillcolor:COLORS.up},decreasing:{line:{color:COLORS.down},fillcolor:COLORS.down},hoverinfo:'none'});
  if(ST_UP.length) traces.push({x:PRICE.t,y:ST_UP,type:'scatter',mode:'lines',name:'Supertrend ↑',yaxis:'y',connectgaps:false,line:{color:COLORS.up,width:1.2},hoverinfo:'skip'});
  if(ST_DN.length) traces.push({x:PRICE.t,y:ST_DN,type:'scatter',mode:'lines',name:'Supertrend ↓',yaxis:'y',connectgaps:false,line:{color:COLORS.down,width:1.2},hoverinfo:'skip'});
 } else {
  traces.push({x:TRADES.map(function(t){return t.exit_time}),y:TRADES.map(function(t){return t.exit_eq}),
   type:'scatter',mode:'lines',name:'Equity',yaxis:'y',line:{color:COLORS.accent,width:1.5},hoverinfo:'x+y'});
 }
 traces.push({x:leX,y:leY,type:'scatter',mode:'markers',name:'Long entry',yaxis:'y',marker:{symbol:'triangle-up',size:9,color:COLORS.long,line:{color:COLORS.background,width:1}},hoverinfo:'skip'});
 traces.push({x:seX,y:seY,type:'scatter',mode:'markers',name:'Short entry',yaxis:'y',marker:{symbol:'triangle-down',size:9,color:COLORS.short,line:{color:COLORS.background,width:1}},hoverinfo:'skip'});
 traces.push({x:exX,y:exY,type:'scatter',mode:'markers',name:'Exit',yaxis:'y',marker:{symbol:'x',size:7,color:exC},hoverinfo:'skip'});
 HI=traces.length;
 traces.push({x:[],y:[],type:'scatter',mode:'lines+markers',name:'Selected',yaxis:'y',line:{width:2,color:COLORS.highlight},marker:{size:14,color:COLORS.highlight},hoverinfo:'skip'});
 if(hasPrice){
  traces.push({x:TRADES.map(function(t){return t.exit_time}),y:TRADES.map(function(t){return t.exit_eq}),
   type:'scatter',mode:'lines',name:'Equity $',yaxis:'y2',visible:'legendonly',line:{color:COLORS.text_tertiary,width:1,dash:'dot'}});
 }
 if(hasHarsi){
  traces.push({x:PRICE.t,y:HARSI_LINE,type:'scatter',mode:'lines',name:'HARSI',yaxis:'y3',line:{color:'#c084fc',width:1.2},hoverinfo:'skip'});
 }

 var layout={
  paper_bgcolor:COLORS.background,plot_bgcolor:COLORS.background,font:{color:COLORS.text_secondary,size:11},
  margin:{l:12,r:hasPrice?72:56,t:6,b:22},hovermode:'x',dragmode:'pan',showlegend:false,
  xaxis:{domain:[0,1],anchor:hasHarsi?'y3':'y',gridcolor:COLORS.grid,rangeslider:{visible:false},
   showspikes:true,spikemode:'across',spikethickness:1,spikecolor:COLORS.text_tertiary,spikedash:'dot'},
  yaxis:{domain:hasHarsi?[0.32,1]:[0,1],side:'right',gridcolor:COLORS.grid,zeroline:false,
   showspikes:true,spikethickness:1,spikecolor:COLORS.text_tertiary,spikedash:'dot'}
 };
 if(hasPrice){
  layout.yaxis2={overlaying:'y',side:'left',showgrid:false,zeroline:false,visible:false};
  var lastC=PRICE.c[PRICE.c.length-1], prevC=PRICE.c[PRICE.c.length-2]!=null?PRICE.c[PRICE.c.length-2]:lastC;
  var tagCol=lastC>=prevC?COLORS.up:COLORS.down;
  layout.annotations=[{xref:'paper',yref:'y',x:1,xanchor:'left',y:lastC,yanchor:'middle',
   text:' '+lastC.toLocaleString()+' ',showarrow:false,font:{color:COLORS.text_primary,size:11},bgcolor:tagCol,bordercolor:tagCol}];
  layout.shapes=[{type:'line',xref:'paper',x0:0,x1:1,yref:'y',y0:lastC,y1:lastC,line:{color:tagCol,width:1,dash:'dot'}}];
 }
 if(hasHarsi){
  layout.yaxis3={domain:[0,0.24],side:'right',anchor:'x',gridcolor:COLORS.grid,zeroline:true,zerolinecolor:COLORS.border};
 }
 // Zoom to the most recent INITIAL_BARS bars (or trades, in the equity fallback) on first render.
 var initX=hasPrice?PRICE.t:TRADES.map(function(t){return t.exit_time});
 if(initX.length){
  var startIdx=Math.max(0,initX.length-INITIAL_BARS);
  layout.xaxis.range=[initX[startIdx],initX[initX.length-1]];
 }
 if(typeof gd.removeAllListeners==='function'){
  gd.removeAllListeners('plotly_hover');
  gd.removeAllListeners('plotly_relayout');
 }
 Plotly.newPlot('chart',traces,layout,{responsive:true,displaylogo:false,scrollZoom:true,modeBarButtonsToRemove:['select2d','lasso2d']});

 function fitY(){
  var xr=gd.layout.xaxis.range; if(!xr)return;
  var x0=new Date(xr[0]).getTime(), x1=new Date(xr[1]).getTime(), up={};
  if(hasPrice){
   var lo=Infinity,hi=-Infinity,hlo=Infinity,hhi=-Infinity;
   for(var i=0;i<PRICE.t.length;i++){
    var tt=new Date(PRICE.t[i]).getTime(); if(tt<x0||tt>x1)continue;
    if(PRICE.l[i]<lo)lo=PRICE.l[i]; if(PRICE.h[i]>hi)hi=PRICE.h[i];
    if(hasHarsi){var hv=HARSI_LINE[i]; if(hv!=null){if(hv<hlo)hlo=hv; if(hv>hhi)hhi=hv;}}
   }
   if(isFinite(lo)&&lo<hi){var pad=(hi-lo)*0.08; up['yaxis.range']=[lo-pad,hi+pad];}
   if(hasHarsi&&isFinite(hlo)&&hlo<hhi){var hp=(hhi-hlo)*0.12; up['yaxis3.range']=[hlo-hp,hhi+hp];}
  } else {
   var elo=Infinity,ehi=-Infinity;
   TRADES.forEach(function(t){
    var tt=new Date(t.exit_time).getTime(); if(tt<x0||tt>x1)return;
    if(t.exit_eq<elo)elo=t.exit_eq; if(t.exit_eq>ehi)ehi=t.exit_eq;
   });
   if(isFinite(elo)&&elo<ehi){var epad=(ehi-elo)*0.1; up['yaxis.range']=[elo-epad,ehi+epad];}
  }
  if(Object.keys(up).length) Plotly.relayout(gd,up);
 }
 gd.on('plotly_relayout',function(ev){
  if(('xaxis.range[0]' in ev)||('xaxis.range' in ev)||('xaxis.autorange' in ev)||('autosize' in ev)) fitY();
 });
 setTimeout(fitY,60);

 var bar=document.getElementById('ohlcbar');
 var fmt=function(n){return (n==null||!isFinite(n))?'-':n.toLocaleString(undefined,{maximumFractionDigits:2})};
 if(hasPrice){
  var showBar=function(i){
   var o=PRICE.o[i],h=PRICE.h[i],l=PRICE.l[i],c=PRICE.c[i];
   var up=c>=o, col=up?COLORS.up:COLORS.down, chg=c-o, cp=o?chg/o*100:0, sg=chg>=0?'+':'';
   var stv=ST_UP[i]!=null?ST_UP[i]:ST_DN[i];
   bar.innerHTML='<b>'+SYM+'</b>'
    +'<span class="lbl">O</span><span style="color:'+col+'">'+fmt(o)+'</span>'
    +'<span class="lbl">H</span><span style="color:'+col+'">'+fmt(h)+'</span>'
    +'<span class="lbl">L</span><span style="color:'+col+'">'+fmt(l)+'</span>'
    +'<span class="lbl">C</span><span style="color:'+col+'">'+fmt(c)+'</span>'
    +'<span style="color:'+col+'">  '+sg+fmt(chg)+' ('+sg+cp.toFixed(2)+'%)</span>'
    +(stv!=null?'<br><span class="st">Supertrend</span><span>'+fmt(stv)+'</span>':'');
  };
  gd.on('plotly_hover',function(ev){
   for(var k=0;k<ev.points.length;k++){if(ev.points[k].data.type==='candlestick'){showBar(ev.points[k].pointNumber);return;}}
  });
  if(PRICE.t.length) showBar(PRICE.t.length-1);
 } else if(bar && TRADES.length){
  var eqVals=TRADES.map(function(t){return t.exit_eq});
  var startEq=INITIAL_CAPITAL, endEq=eqVals[eqVals.length-1], peakEq=Math.max(INITIAL_CAPITAL,Math.max.apply(null,eqVals));
  bar.innerHTML='<span class="lbl">Equity</span><span class="st">start</span>'+fmt(startEq)+
   '<span class="lbl">end</span>'+fmt(endEq)+'<span class="lbl">peak</span>'+fmt(peakEq);
 }
}

function sel(i,rowEl){
 var d=TRADES[i]; if(!d)return;
 var c=d.dir==='long'?COLORS.long:COLORS.short;
 var ey=hasPrice?d.entry_px:d.entry_eq, xy=hasPrice?d.exit_px:d.exit_eq;
 Plotly.restyle(gd,{x:[[d.entry_time,d.exit_time]],y:[[ey,xy]],'line.color':c,'marker.color':c},[HI]);
 var a=new Date(d.entry_time).getTime(), b=new Date(d.exit_time).getTime(), pad=Math.max((b-a)*2,6*3600*1000);
 Plotly.relayout(gd,{'xaxis.range':[new Date(a-pad).toISOString(),new Date(b+pad).toISOString()]});
 document.querySelectorAll('tr.active').forEach(function(r){r.classList.remove('active');});
 if(rowEl)rowEl.classList.add('active');
}
document.querySelectorAll('tr[data-i]').forEach(function(r){
 r.addEventListener('click',function(){sel(+r.dataset.i,r);});
});

var savedTheme='dark';
try{savedTheme=localStorage.getItem('trg-theme')||'dark';}catch(e){}
applyTheme(savedTheme);
console.log('Report initialized for',SYM,'with',TRADES.length,'trades');
</script>
</body></html>
